# openmc-prism/.dockerignore
# Files excluded from the Docker build context.
# The build context is the openmc-prism/ folder itself.

# Git internals (never needed inside image)
.git
.gitignore
.gitattributes

# CI/CD config
.github/

# Local environment / secrets
.env
*.env
.env.*

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# Jupyter checkpoints
.ipynb_checkpoints/

# Test outputs
.pytest_cache/
.coverage
htmlcov/

# OS / archive artefacts
.DS_Store
Thumbs.db
__MACOSX/

# Large local data — mounted as a volume, never baked into the image
nuclear_data/
workspace/

# Note: Notebooks/, environments/, openmc_bo/, openmc_ga/, and Results/ are
# intentionally NOT excluded — they're copied into the image so the
# container ships with notebooks, the model-specific environments, the
# optimisation packages, and the existing sample results out of the box.

# Editor configs
.vscode/
.idea/
*.swp
*.swo

